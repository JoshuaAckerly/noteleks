{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "prebuild": "npm run convert-atlas -- public/sprites",
        "build": "vite build",
        "dev": "vite",
        "convert-atlas": "node scripts/convert_packer_to_phaser_atlas.js",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.cjs",
        "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.cjs --watch"
    },
    "dependencies": {
        "@esotericsoftware/spine-phaser": "^4.1.55",
        "phaser": "^3.90.0"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.28.5",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@types/jest": "^30.0.0",
        "babel-jest": "^30.2.0",
        "jest": "^30.2.0",
        "laravel-vite-plugin": "^3.0.0",
        "vite": "^8.0.0"
    }
}
